# Logging and polling controls for docker-compose.yml
# Copy this file to .env to override defaults.

# Backend request access logs (0=off, 1=on)
UVICORN_ACCESS_LOG=0

# Frontend nginx access logs (0=off, 1=on)
NGINX_ACCESS_LOG=0

# Frontend task polling interval in milliseconds (used at build time)
VITE_TASK_POLL_INTERVAL_MS=2000
